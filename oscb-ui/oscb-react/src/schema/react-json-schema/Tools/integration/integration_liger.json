{
  "type": "object",
  "properties": {
    "parameters": {
      "type":"object",
      "title": "Parameters for Integration Process",  
      "properties": {
        "species": {
          "type": ["string", "null"],
          "title": "Species Type"
        },
        "organ_part": {
          "type": ["string", "null"],
          "title": "Organ Part"
        },
        "n_hvg": {
          "type": "integer",
          "title": "Number of Highly Variable Genes for Heatmap",
          "default": 50
        },
        "cluster_colname": {
          "type": ["string", "null"],
          "title": "Cluster Column Name",
          "description": "Choose the cluster column for cell type annotation. If not specified, the default Leiden clustering will be used."
        },
        "do_umap": {
          "type": "boolean",
          "title": "Do you want to perform UMAP after processing?",
          "default": true,
          "format": "switch",
          "description": "Toggle this switch to decide whether to perform UMAP (Uniform Manifold Approximation and Projection) analysis after processing your data."
        },
        "do_cluster": {
          "type": "boolean",
          "title": "Do you want to perform Cluster after processing?",
          "default": true,
          "format": "switch",
          "description": "Toggle this switch to decide whether to perform Cluster analysis after processing your data."
        },
        "integration_params": {
          "type": "object",
          "title": "Integration Parameters",
          "required": [
            "methods",
            "batch_key"
          ],
          "properties": {
            "methods": {
              "type": "array",
              "title": "Method",
              "items": {
                "type": "string",
                "enum": [
                  "Liger",
                  "Harmony",
                  "Seurat",
                  "scVI"
                ]
              },
              "default": [
                "Liger"
              ],
              "uniqueItems": true,
              "minItems": 1
            },
            "batch_key": {
              "type": "string",
              "title": "Batch Key",
              "description": "Please specify the Batch Key.",
              "default": ""
            },
            "pseudo_replicates": {
              "type": "integer",
              "title": "Pseudo Replicates",
              "description": "Please specify the number of samples for each batch if you use pooled samples for sc-RNA sequencing.",
              "default": 0
            },
            "default_assay": {
              "type": ["string", "null"],
              "title": "Default Assay (If applicable)",
              "default": "RNA"
            },
            "npcs": {
              "type": "integer",
              "default": 30
            },
            "dims": {
              "type": "integer",
              "default": 30
            },
            "resolution": {
              "type": "number",
              "title": "Resolution:",
              "default": 0.5
            }
          }
        }
      }
    }
  }
}