{
  "type": "object",
  "properties": {
    "parameters": {
      "type": "object",
      "title": "Parameters for Clustering Workflow",
      "properties": {
        "species": {
          "type": ["string", "null"],
          "title": "Species Type"
        },
        "organ_part": {
          "type": ["string", "null"],
          "title": "Organ Part"
        },
        "qc_params": {
          "type": "object",
          "title": "Quality Control Parameters",
          "required": [
            "methods"
          ],
          "properties": {
            "methods": {
              "type": "array",
              "title": "Method",
              "items": {
                "type": ["string", "null"],
                "enum": [
                  "Bioconductor",
                  "Seurat",
                  "Scanpy",
                  "Dropkick"
                ]
              },
              "default": [
                "Scanpy"
              ],
              "uniqueItems": true
            },
            "assay": {
              "type": ["string", "null"],
              "title": "Default Assay (If applicable)",
              "default": "RNA"
            },
            "layer": {
              "type": ["string", "null"],
              "title": "Layer",
              "description": "Specify the layer",
              "default": ""
            },
            "min_genes": {
              "type": "integer",
              "title": "Min Genes",
              "default": 200
            },
            "max_genes": {
              "type": "integer",
              "title": "Max Genes",
              "default": 50000
            },
            "min_cells": {
              "type": "integer",
              "title": "Min Cells",
              "default": 2
            },
            "pct_counts_mt": {
              "type": "integer",
              "title": "Percentage of Counts in Mitochondrial Genes",
              "default": 3
            },
            "target_sum": {
              "type": "integer",
              "title": "Target Sum:",
              "default": 10000
            },
            "n_top_genes": {
              "type": "integer",
              "title": "Highly Variable Genes (n_top_genes):",
              "default": 2000
            },
            "doublet_rate": {
              "type": "number",
              "title": "Expected Doublet Rate: ",
              "default": 0.08
            },
            "regress_cell_cycle": {
              "type": "boolean",
              "title": "Regress Cell Cycle",
              "default": false,
              "format": "switch"
            }
          }
        },
        "reduction_params": {
          "type": "object",
          "title": "Visualization Parameters",
          "properties": {
            "n_neighbors": {
              "type": "integer",
              "default": 15
            },
            "n_pcs": {
              "type": "integer",
              "default": 20
            },
            "resolution": {
              "type": "number",
              "title": "Resolution:",
              "default": 0.5
            },
            "n_hvg": {
              "type": "integer",
              "title": "Number of Highly Variable Genes for Heatmap",
              "default": 50
            },
            "cluster_colname": {
              "type": ["string", "null"],
              "title": "Cluster Column Name",
              "description": "Choose the cluster column for cell type annotation. If not specified, the default Leiden clustering will be used."
            }
          }
        },
        "process_type": {
          "type": ["string", "null"],
          "title": "Process Type",
          "default": "Normalization"
        }
      },
      "required": [
        "process_type"
      ],
      "allOf": [
        {
          "if": {
            "properties": {
              "process_type": {
                "const": "Normalization"
              }
            }
          },
          "then": {
            "properties": {
              "normalization_params": {
                "type": "object",
                "title": "Normalization Parameters",
                "required": [
                  "methods"
                ],
                "properties": {
                  "methods": {
                    "type": "array",
                    "title": "Method",
                    "items": {
                      "type": "string",
                      "enum": [
                        "DESeq2",
                        "FPKM",
                        "logCP10K",
                        "logCPM",
                        "Pearson_Residuals",
                        "RLE",
                        "scran",
                        "SCTransform",
                        "SCTransform_v2",
                        "TMM",
                        "TPM",
                        "UpperQuartile"
                      ]
                    },
                    "default": [
                      "logCP10K"
                    ],
                    "uniqueItems": true
                  }
                }
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "process_type": {
                "const": "Imputation"
              }
            }
          },
          "then": {
            "properties": {
              "imputation_params": {
                "type": "object",
                "title": "Imputation Parameters",
                "required": [
                  "methods"
                ],
                "properties": {
                  "methods": {
                    "type": "array",
                    "title": "Method",
                    "items": {
                      "type": "string",
                      "enum": [
                        "Magic",
                        "Saver"
                      ]
                    },
                    "default": [
                      "Magic"
                    ],
                    "uniqueItems": true
                  }
                }
              }
            }
          }
        }
      ]
    }
  }
}